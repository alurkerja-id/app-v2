    <bpmn:sequenceFlow id="Flow_179s9vf" sourceRef="Review_Contract" targetRef="Gateway_1h0c06u" />
    <bpmn:sequenceFlow id="Flow_06dcw0q" sourceRef="Activity_1wwntyt" targetRef="Review_Contract">
      <bpmn:extensionElements>
        <camunda:executionListener event="take">
          <camunda:script scriptFormat="groovy">def reviewers = []

if (execution.getVariable("ProcurementReviewRequired")?.toLowerCase() == "yes") {
    reviewers.add("procurement@yopmail.com")
}
if (execution.getVariable("FinanceReviewRequired")?.toLowerCase() == "yes") {
    reviewers.add("finance@yopmail.com")
}
if (execution.getVariable("TaxReviewRequired")?.toLowerCase() == "yes") {
    reviewers.add("tax@yopmail.com")
}
if (execution.getVariable("ComplianceReviewRequired")?.toLowerCase() == "yes") {
    reviewers.add("compliance@yopmail.com")
}

execution.setVariable("reviewers", reviewers)</camunda:script>
        </camunda:executionListener>
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
