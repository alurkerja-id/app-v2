      <bpmn:extensionElements>
        <email:emails>
          <email:email recipient="legal@yopmail.com" emailConfig="Sendriaa" subject="New Contract" messageType="write" message="Dear Legal Team,&#10;&#10;A new contract request has been submitted through the Contract Lifecycle Management system. Below are the details of the request:&#10;&#10;Contract Request Information&#10;&#10;Request ID: ${reqID}&#10;Contract Title: ${title}&#10;Requester Name: ${reqName}&#10;Position/Role: ${role}&#10;Requester Phone Number: ${number}&#10;&#10;Best Regrads" name="Email_0hq163u" value="" />
        </email:emails>
        <notification:notifications />
        <camunda:executionListener expression="${emailContext.getInstance(&#34;262&#34;, &#34;Sendriaa&#34;).setExecution(execution).putAllProcessVariables().setTo(&#34;legal@yopmail.com&#34;).setSubject(&#34;New Contract&#34;).setText(&#34;Dear Legal Team,&#10;&#10;A new contract request has been submitted through the Contract Lifecycle Management system. Below are the details of the request:&#10;&#10;Contract Request Information&#10;&#10;Request ID: ${reqID}&#10;Contract Title: ${title}&#10;Requester Name: ${reqName}&#10;Position/Role: ${role}&#10;Requester Phone Number: ${number}&#10;&#10;Best Regrads&#34;).send()}" event="take" emailRef="Email_0hq163u" />
